# ===============================================================
# .gitignore — Quantum-Enhanced Deep RL for CBDC Optimization
# ===============================================================

# ── General ──────────────────────────────────────────────────────────────────
*.log
*.tmp
*.swp
*~
.DS_Store
Thumbs.db

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
ENV/
.venv/
*/venv/
*/ENV/

# Distribution / packaging
.Python
build/
dist/
downloads/
eggs/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Testing & coverage ────────────────────────────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# ── Type checkers ─────────────────────────────────────────────────────────────
.mypy_cache/

# ── Linters ───────────────────────────────────────────────────────────────────
.ruff_cache/

# ── Build / compiled artefacts ────────────────────────────────────────────────
/build/
/dist/
/out/
/target/
/bin/
/obj/
*.o
*.a
*.so
*.dll
*.class
*.pyc
*.whl

# ── Project-specific ─────────────────────────────────────────────────────────
# MLflow experiment tracking
mlruns/

# Training outputs (logs, checkpoints, plots)
logs/

# Trained model weights
*.pt
*.pth
*.ckpt

# Hydra output directories
outputs/
multirun/

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/
docker-compose.override.yml
